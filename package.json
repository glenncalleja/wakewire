{
  "name": "bridgehead",
  "version": "0.1.0",
  "description": "Break the loop — GitHub, Gmail, and Slack events pushed straight into your local Codex threads, no polling.",
  "keywords": [
    "codex",
    "webhooks",
    "github",
    "gmail",
    "mcp",
    "automation",
    "agent"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.18"
  },
  "bin": {
    "bridgehead": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "plugin",
    "recipes",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@octokit/webhooks-methods": "^6.0.0",
    "@openai/codex-sdk": "^0.142.5",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.18.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^14.0.0",
    "google-auth-library": "^10.9.0",
    "hono": "^4.12.27",
    "html-to-text": "^10.0.0",
    "imapflow": "^1.4.3",
    "mailparser": "^3.9.12",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "smee-client": "^5.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/html-to-text": "^9.0.4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
